<Window x:Class="ERP.UI.Views.ProduktDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Produkt hinzufügen / bearbeiten"
        Height="520" Width="650"
        Background="#1C1E26"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titel -->
        <TextBlock Text="📦 Produktdetails"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#3B82F6"
                   Margin="0,0,0,15"/>

        <!-- Inhalt -->
        <Grid Grid.Row="1" Margin="0,10,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Bildauswahl -->
            <Border Grid.Column="0"
                    BorderBrush="#3B82F6"
                    BorderThickness="1"
                    CornerRadius="10"
                    Background="#2B2E3D"
                    Padding="10"
                    Margin="0,0,20,0">
                <StackPanel>
                    <Image Source="{Binding BildPfad}" 
                           Height="160" 
                           Stretch="UniformToFill"
                           Margin="0,0,0,10"
                           />
                    <Button Content="🖼 Bild auswählen"
                            Command="{Binding BildAuswählenCommand}"
                            Background="#3B82F6"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="8,4"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Formulareingaben -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" >

                <!-- Produktname -->
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Produktname:" Foreground="#E5E7EB" FontSize="14"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2E3142"
                             Foreground="White"
                             BorderBrush="#3B82F6"
                             Padding="5"/>
                </StackPanel>

                <!-- Kategorie -->
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Kategorie:" Foreground="#E5E7EB" FontSize="14"/>
                    <TextBox Text="{Binding Kategorie, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2E3142"
                             Foreground="White"
                             BorderBrush="#3B82F6"
                             Padding="5"/>
                </StackPanel>

                <!-- Preis -->
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Preis (€):" Foreground="#E5E7EB" FontSize="14"/>
                    <TextBox Text="{Binding Preis, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Background="#2E3142"
                             Foreground="White"
                             BorderBrush="#3B82F6"
                             Padding="5"/>
                </StackPanel>

                <!-- Lagerbestand -->
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Lagerbestand:" Foreground="#E5E7EB" FontSize="14"/>
                    <TextBox Text="{Binding Lagerbestand, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2E3142"
                             Foreground="White"
                             BorderBrush="#3B82F6"
                             Padding="5"/>
                </StackPanel>

                <!-- Ablaufdatum -->
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Ablaufdatum:" Foreground="#E5E7EB" FontSize="14"/>
                    <DatePicker SelectedDate="{Binding Ablaufdatum, Mode=TwoWay}"
                                Background="#2E3142"
                                Foreground="#2E3142"
                                BorderBrush="#3B82F6"
                                DisplayDateStart="{x:Static sys:DateTime.Now}"
                                Padding="3"/>
                </StackPanel>

            </StackPanel>
        </Grid>

        <!-- Fußbereich mit Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button Content="💾 Speichern"
                    Command="{Binding SpeichernCommand}"
                    Background="#22C55E"
                    Foreground="White"
                    FontWeight="Bold"
                    Padding="10,5"
                    BorderThickness="0"
                    Cursor="Hand"/>

            <Button Content="✖ Abbrechen"
                    Command="{Binding AbbrechenCommand}"
                    Background="#EF4444"
                    Foreground="White"
                    FontWeight="Bold"
                    Padding="10,5"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
