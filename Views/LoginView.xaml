<UserControl x:Class="ERP.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <!-- Ressourcen, die wir hier lokal bereitstellen -->
    <UserControl.Resources>
        <!-- Für Sichtbarkeit (Busy/Spinner) -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <!-- Hintergrund der Login-Karte -->
    <Grid Background="{DynamicResource Menu}">
        <Border Width="320" Height="370"
                Background="{DynamicResource Korper}"
                BorderBrush="{DynamicResource BlauTaste}"
                BorderThickness="1"
                CornerRadius="15"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <!-- Inhalt der Login-Karte -->
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Titel -->
                    <RowDefinition Height="Auto"/>
                    <!-- Spinner -->
                    <RowDefinition Height="Auto"/>
                    <!-- Fehlermeldung -->
                    <RowDefinition Height="Auto"/>
                    <!-- E-Mail -->
                    <RowDefinition Height="Auto"/>
                    <!-- Passwort -->
                    <RowDefinition Height="Auto"/>
                    <!-- Anmelden -->
                    <RowDefinition Height="Auto"/>
                    <!-- Registrierung -->
                </Grid.RowDefinitions>

                <!-- Titel -->
                <TextBlock Grid.Row="0"
                           Text="Benutzeranmeldung"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource Text}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Spinner (benötigt einen vorhandenen Style 'SpinnerStyle') -->
               

                <!-- Fehlermeldung aus dem ViewModel -->
                <TextBlock Grid.Row="2"
                           Text="{Binding Benutzer.Authentifizierung.Anmeldung.Nachricht}"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Benutzer.Authentifizierung.Anmeldung.IstNachrichtBereit}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- E-Mail Eingabe -->
                <Grid Grid.Row="3" Margin="0,10">
                    <TextBox x:Name="BenutzerEmail"
                             Height="30" Width="250"
                             VerticalContentAlignment="Center"
                             Text="{Binding Benutzer.Authentifizierung.Anmeldung.Email,
                                            Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <!-- „Platzhalter“ (sichtbar wenn leer) -->
                    <TextBlock Text="E-Mail"
                               Foreground="Gray"
                               Margin="19,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=BenutzerEmail}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Passwort Eingabe (PasswordBox kann nicht direkt binden) -->
                <Grid Grid.Row="4" Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104*"/>
                        <ColumnDefinition Width="35*"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="PasswortBox"
                                 Height="30" Width="250"
                                 PasswordChanged="PasswortGeändert" Grid.ColumnSpan="2" Margin="14,0,14,0"/>
                    <!-- „Platzhalter“ für Passwort -->
                    <TextBlock Text="Passwort"
                               Foreground="Gray"
                               Margin="19,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False" Grid.ColumnSpan="2">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Password, ElementName=PasswortBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Anmelden Button -->
                <Button Grid.Row="5"
                        Content="Anmelden"
                        Width="250" Height="35"
                        Margin="0,10"
                        FontWeight="Bold"
                        Style="{DynamicResource GraueTaste}"
                        Command="{Binding Benutzer.BenutzerAnmelden}"/>

                <!-- Registrierung -->
                <StackPanel Grid.Row="6"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <TextBlock Text="Noch kein Konto?"
                               Foreground="{DynamicResource Text}"
                               Margin="0,0,5,0"/>
                    <Button Content="Registrieren"
                            Command="{Binding Benutzer.Oberfläche.RegistrierungAnzeigen}"
                            Style="{DynamicResource Registrieren}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
