<UserControl x:Class="ERP.UI.Views.KundenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:viewmodel="clr-namespace:ERP.UI.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:KundenViewModel}"
             mc:Ignorable="d"
             Background="#1C1E26">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titel -->
        <Border Grid.Row="0"
                Background="#1E202C"
                BorderBrush="#2A2E3B"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="50"
                        Height="50"
                        Background="#232735"
                        BorderBrush="#31384C"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="0,0,14,0">
                    <Grid>
                        <TextBlock Text=""
                                   FontFamily="FontAwesome"
                                   FontSize="24"
                                   Foreground="#3B82F6"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Kundenübersicht"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#E5E7EB"/>

                    <TextBlock Text="Übersicht und Verwaltung aller Kunden"
                               FontSize="13"
                               Foreground="#9CA3AF"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Suchleiste -->
        <Border Grid.Row="1"
                Background="#1E202C"
                BorderBrush="#2A2E3B"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="260"
                         Margin="0,0,10,0"
                         Text="{Binding Suchtext,UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Suche nach Name, E-Mail, Telefon oder ID"
                         FontSize="14"
                         Height="34"
                         VerticalAlignment="Center"
                         Background="#252735"
                         Foreground="#FFFFFF"
                         CaretBrush="White"
                         BorderBrush="#3B82F6"
                         BorderThickness="1"
                         Padding="8,4"/>
            </StackPanel>
        </Border>

        <!-- Tabelle -->
        <Border Grid.Row="2"
                Background="#1E202C"
                BorderBrush="#2A2E3B"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14">
            <DataGrid ItemsSource="{Binding KundenListe}"
                      SelectedItem="{Binding AusgewählterKunde, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      Background="#252735"
                      Foreground="#E5E7EB"
                      RowBackground="#2E3142"
                      AlternatingRowBackground="#35384A"
                      BorderBrush="#3A3D4A"
                      BorderThickness="0"
                      RowHeight="38"
                      FontSize="14"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      CanUserResizeRows="False"
                      CanUserReorderColumns="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2E3240"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#3A3D4A"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#2E3142"/>
                        <Setter Property="Foreground" Value="#E5E7EB"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3F55"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4C6EF5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,0,10,0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#E5E7EB"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding KundeID}" Width="60"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="2*"/>
                    <DataGridTextColumn Header="Telefon" Binding="{Binding Telefonnummer}" Width="*"/>
                    <DataGridTextColumn Header="Erstellt Am"
                                        Binding="{Binding ErstelltAm, StringFormat={}{0:dd.MM.yyyy}}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>