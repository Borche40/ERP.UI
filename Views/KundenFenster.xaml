<Window x:Class="ERP.UI.Views.KundenFenster"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:views="clr-namespace:ERP.UI.Views"
        xmlns:viewmodel="clr-namespace:ERP.UI.ViewModel"
        mc:Ignorable="d"
        Title="Kundenverwaltung"
        Width="1050"
        Height="720"
        Background="#1C1E26"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <viewmodel:KundenViewModel/>
    </Window.DataContext>

    <Window.Resources>

        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="AccentRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="AccentGray" Color="#2E3240"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10"
                                      Opacity="0.22"
                                      ShadowDepth="1"
                                      Color="Black"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.93"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KundenDataGrisStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#171A24"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E3240"/>
            <Setter Property="VerticalGridLinesBrush" Value="#2E3240"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>

        <Style x:Key="KundenDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#202433"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#24293A"/>
                </Trigger>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30374B"/>
                </Trigger>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#355DCC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="KundenHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#262B3A"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#3A3F52"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#202433"/>
            <Setter Property="BorderBrush" Value="#353B4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#171A24"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="RowBackground" Value="#202433"/>
            <Setter Property="AlternatingRowBackground" Value="#24293A"/>
            <Setter Property="BorderBrush" Value="#34394A"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#34394A"/>
            <Setter Property="VerticalGridLinesBrush" Value="#34394A"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

    </Window.Resources>

    <Grid Background="#1C1E26">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                Background="#151822"
                BorderBrush="#2B3140"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="42"
                            Height="42"
                            Background="#1E2432"
                            BorderBrush="#2E3750"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,14,0">
                        <Grid>
                            <TextBlock Text=""
                                       FontFamily="FontAwesome"
                                       FontSize="20"
                                       Foreground="#60A5FA"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Kundenverwaltung"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#F3F4F6"/>

                        <TextBlock Text="ERP • Kundenstammdaten und Verwaltung"
                                   FontSize="12"
                                   Foreground="#8E97AA"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#1D2230"
                        BorderBrush="#31384B"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Modul"
                                   Foreground="#8E97AA"
                                   FontSize="12"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Kunden"
                                   Foreground="#E5E7EB"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- SEARCH / FILTER BAR -->
            <Border Grid.Row="0"
                    Background="#181C27"
                    BorderBrush="#2C3242"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Suche"
                               Foreground="#A7B0C0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <Border Grid.Column="1"
                            Background="#202433"
                            BorderBrush="#3559B7"
                            BorderThickness="1"
                            CornerRadius="7"
                            Height="36">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text=""
                                       FontFamily="FontAwesome"
                                       Foreground="#7E8AA5"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     x:Name="SuchtextBox"
                                     Width="Auto"
                                     Margin="0"
                                     Text="{Binding Suchtext,UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Suche nach Name,E-Mail,Telefon oder ID"
                                     FontSize="14"
                                     Height="34"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     Foreground="#FFFFFF"
                                     CaretBrush="White"
                                     BorderBrush="Transparent"
                                     BorderThickness="0"
                                     Padding="0,0,10,0"
                                     SnapsToDevicePixels="True"
                                     TextOptions.TextFormattingMode="Display"
                                     TextOptions.TextRenderingMode="Aliased"
                                     IsHitTestVisible="True"
                                     Focusable="True"
                                     IsTabStop="True"
                                     IsReadOnly="False"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- EDIT AREA -->
            <Border Grid.Row="2"
                    Background="#181C27"
                    BorderBrush="#2C3242"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Bearbeitungsbereich"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F3F4F6"/>

                            <Border Background="#20283A"
                                    BorderBrush="#33405A"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,2"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Kundendaten"
                                           Foreground="#93C5FD"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="Erfassen oder vorhandenen Kunden bearbeiten"
                                   Foreground="#8E97AA"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Width="220"
                                 Text="{Binding AusgewählterKunde.Name, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Name des Kunden"/>

                        <TextBox Grid.Column="2"
                                 Width="280"
                                 Text="{Binding AusgewählterKunde.Email, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="E-Mail-Adresse"/>

                        <TextBox Grid.Column="4"
                                 Width="190"
                                 Text="{Binding AusgewählterKunde.Telefonnummer, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Telefonnummer"/>

                        <Button Grid.Column="6"
                                Style="{StaticResource ModernButton}"
                                Command="{Binding HinzufügenCommand}"
                                Background="{StaticResource AccentGreen}"
                                MinWidth="145"
                                Margin="0,0,0,0">
                            <TextBlock Text=" Neuer Kunde"
                                       FontFamily="FontAwesome"
                                       FontSize="14"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- DATA SECTION -->
            <Border Grid.Row="4"
                    Background="#181C27"
                    BorderBrush="#2C3242"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- DATA HEADER -->
                    <Grid Grid.Row="0" Margin="16,0,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Kundenliste"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F3F4F6"/>

                            <TextBlock Text=" / Stammdaten"
                                       FontSize="16"
                                       Foreground="#7E8AA5"
                                       Margin="4,0,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Background="#20283A"
                                    BorderBrush="#33405A"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,3">
                                <TextBlock Text="Aktive Ansicht"
                                           Foreground="#93C5FD"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#2C3242"/>

                    <!-- DATA GRID -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding KundenListe}"
                              SelectedItem="{Binding AusgewählterKunde, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              AlternationCount="2"
                              Margin="14,14,14,14"
                              RowHeight="40"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              FontSize="14"
                              Background="#171A24"
                              Foreground="#E5E7EB"
                              HorizontalGridLinesBrush="#2E3240"
                              VerticalGridLinesBrush="#2E3240"
                              Style="{StaticResource KundenDataGrisStyle}"
                              RowStyle="{StaticResource KundenDataGridRowStyle}"
                              ColumnHeaderStyle="{StaticResource KundenHeaderStyle}">

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,0,10,0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding KundeID}" Width="70"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="2*"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Telefonnummer}" Width="*"/>
                            <DataGridTextColumn Header="Erstellt Am"
                                                Binding="{Binding ErstelltAm, StringFormat={}{0:dd.MM.yyyy}}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ACTION BAR -->
            <Border Grid.Row="6"
                    Background="#181C27"
                    BorderBrush="#2C3242"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Aktionen"
                               Foreground="#A7B0C0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding AktualisierenCommand}"
                                MinWidth="135">
                            <TextBlock Text=" Aktualisieren"
                                       FontFamily="FontAwesome"
                                       FontSize="14"/>
                        </Button>

                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding ExportierenCommand}"
                                Background="#2563EB"
                                Margin="6,0,0,0"
                                MinWidth="160">
                            <TextBlock Text=" Exportieren (PDF)"
                                       FontFamily="FontAwesome"
                                       FontSize="14"/>
                        </Button>

                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding ExportExcelCommand}"
                                Background="#22C55E"
                                Margin="6,0,0,0"
                                MinWidth="175">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xf2c3;"
                                           FontFamily="FontAwesome"
                                           FontSize="14"
                                           Foreground="White"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Exportieren (Excel)"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ModernButton}"
                                Background="{StaticResource AccentRed}"
                                Command="{Binding LöschenCommand}"
                                MinWidth="120">
                            <TextBlock Text=" Löschen"
                                       FontFamily="FontAwesome"
                                       FontSize="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>