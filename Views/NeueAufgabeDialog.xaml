<Window x:Class="ERP.UI.Views.NeueAufgabeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodel="clr-namespace:ERP.UI.ViewModel"
        mc:Ignorable="d"
        Title="Neue Aufgabe"
        Width="620" Height="520"
        MinHeight="500"
        MinWidth="600"
        Background="#1C1E26"
        
        
        FontFamily="Segoe UI"
        d:DataContext="{d:DesignInstance Type=viewmodel:NeueAufgabeDialogViewModel,IsDesignTimeCreatable=False}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titel im Dialog -->
        <TextBlock Text="📝 Aufgabendetails"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#3B82F6"
                   Margin="0,0,0,15"/>

        <!-- Inhalt (SCROLLBAR!) -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,6,0">

            <StackPanel>

                <!-- TicketID (nur Anzeige) -->
                <TextBlock Text="TicketID:" Foreground="#E5E7EB"/>
                <TextBox Text="{Binding TicketID}" 
                         IsReadOnly="True"
                         Background="#2E3142"
                         Foreground="White"
                         BorderBrush="#3B82F6"
                         Padding="6"/>

                <!-- Titel -->
                <TextBlock Text="Titel:" Foreground="#E5E7EB" Margin="0,10,0,0"/>
                <TextBox Text="{Binding Titel,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                         Background="#2E3142"
                         Foreground="White"
                         BorderBrush="#3B82F6"
                         Padding="6"/>

                <!-- Beschreibung -->
                <TextBlock Text="Beschreibung:" Foreground="#E5E7EB" Margin="0,10,0,0"/>
                <TextBox Text="{Binding Beschreibung}"
                         Background="#2E3142"
                         Foreground="White"
                         BorderBrush="#3B82F6"
                         Padding="6"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"/>

                <!-- Priorität -->
                <TextBlock Text="Priorität:" Foreground="#E5E7EB" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding PrioritätenListe}"
                          SelectedItem="{Binding Priorität}"
                          Background="#2E3142"
                          Foreground="White"
                          BorderBrush="#3B82F6"
                          Padding="5"/>

                <!-- Kategorie -->
                <TextBlock Text="Kategorie:" Foreground="#E5E7EB" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding KategorienListe}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="Name"
                          SelectedValue="{Binding Kategorie, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Background="#2E3142"
                          Foreground="White"
                          BorderBrush="#3B82F6"
                          Padding="5">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#2E3142"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>

                <!-- Fälligkeitsdatum -->
                <TextBlock Text="Fälligkeitsdatum:" Foreground="#E5E7EB" Margin="0,10,0,0"/>
                <DatePicker SelectedDate="{Binding FälligkeitsDatum}"
                            Background="#2E3142"
                            BorderBrush="#3B82F6"
                            Padding="4"/>

                <!-- мал spacer за да не „лепи“ на копчиња -->
                <Border Height="10" Background="Transparent"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Fußbereich (Buttons) -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="💾 Speichern"
                    Command="{Binding SpeichernCommand}"
                    Background="#22C55E"
                    Foreground="White"
                    FontWeight="Bold"
                    Padding="10,5"
                    BorderThickness="0"/>

            <Button Content="✖ Abbrechen"
                    Command="{Binding AbbrechenCommand}"
                    Background="#EF4444"
                    Foreground="White"
                    FontWeight="Bold"
                    Padding="10,5"
                    BorderThickness="0"
                    Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>