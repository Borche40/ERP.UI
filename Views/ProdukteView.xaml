<UserControl x:Class="ERP.UI.Views.ProdukteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:viewmodel="clr-namespace:ERP.UI.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:ProdukteViewModel}"
             mc:Ignorable="d"
             Background="#1C1E26">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titelbereich -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Border Width="46"
                        Height="46"
                        CornerRadius="10"
                        Background="#232735"
                        BorderBrush="#2F364A"
                        BorderThickness="1"
                        Margin="0,0,12,0">
                    <Grid>
                        <TextBlock Text=""
                                   FontFamily="FontAwesome"
                                   FontSize="24"
                                   Foreground="#00C853"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <StackPanel>
                    <TextBlock Text="Produkteübersicht"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#E5E7EB"/>

                    <TextBlock Text="Verwaltung, Suche und Auswertung aller Produkte"
                               FontSize="13"
                               Foreground="#9CA3AF"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#232735"
                    BorderBrush="#2F364A"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,8"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Produkte:"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#9CA3AF"
                               Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ProdukteListe.Count}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#E5E7EB"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Toolbar / Aktionsbereich -->
        <Border Grid.Row="1"
                Background="#20242F"
                BorderBrush="#2F364A"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Suche -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Suche"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#9CA3AF"
                               Margin="0,0,0,8"/>

                    <TextBox Width="300"
                             Height="38"
                             Text="{Binding Suchtext, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             ToolTip="Suche nach Produktname oder Kategorie"
                             FontSize="14"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Hauptaktionen -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Aktionen"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#9CA3AF"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content=" Neues Produkt"
                                FontFamily="FontAwesome"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding NeuesProduktCommand}"/>

                        <Button Content=" Bearbeiten"
                                FontFamily="FontAwesome"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding BearbeitenCommand}"/>

                        <Button Command="{Binding AktualisierenCommand}">
                            <Button.Style>
                                <Style TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text=""
                                       FontFamily="FontAwesome"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                                                    <TextBlock Text="Aktualisieren"
                                       VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IstAmLaden}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">

                                                            <!-- 🔄 ROTIERENDER SPINNER -->
                                                            <TextBlock Text=""
                                               FontFamily="FontAwesome"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               RenderTransformOrigin="0.5,0.5">

                                                                <TextBlock.RenderTransform>
                                                                    <RotateTransform Angle="0"/>
                                                                </TextBlock.RenderTransform>

                                                                <TextBlock.Triggers>
                                                                    <EventTrigger RoutedEvent="Loaded">
                                                                        <BeginStoryboard>
                                                                            <Storyboard RepeatBehavior="Forever">
                                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                                         From="0"
                                                                         To="360"
                                                                         Duration="0:0:1"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </TextBlock.Triggers>

                                                            </TextBlock>

                                                            <!-- TEXT -->
                                                            <TextBlock Text="Wird aktualisiert..."
                                               VerticalAlignment="Center"/>

                                                        </StackPanel>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content=" Löschen"
                                FontFamily="FontAwesome"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding LöschenCommand}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Werkzeuge -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Werkzeuge"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#9CA3AF"
                               Margin="0,0,0,8"
                               />

                    <StackPanel Orientation="Horizontal">
                        <Button Content=" Audit"
                                FontFamily="FontAwesome"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AuditCommdand}" Margin="0,0,8,0" />

                        <Button Content=" Export (PDF)"
                                FontFamily="FontAwesome"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ExportPdfCommand}"/>

                        <Button Content=" Export (Excel)"
                                FontFamily="FontAwesome"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ExportExcelCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding ProdukteListe}"
                  SelectedItem="{Binding AusgewähltesProdukt, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  RowHeight="70"
                  Style="{StaticResource ErpDataGrid}"
                  FontSize="14">

            <DataGrid.Columns>
                <!-- Bild -->
                <DataGridTemplateColumn Header="Bild" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding BildPfad}"
                                   Height="60"
                                   Width="60"
                                   Stretch="UniformToFill"
                                   Margin="5"
                                   SnapsToDevicePixels="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Produktname -->
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding ProduktName}"
                                    Width="2*"/>

                <!-- Kategorie -->
                <DataGridTextColumn Header="Kategorie"
                                    Binding="{Binding Kategorie}"
                                    Width="*"/>

                <!-- Preis -->
                <DataGridTextColumn Header="Preis (€)"
                                    Binding="{Binding Preis, StringFormat={}{0:F2}}"
                                    Width="*"/>

                <!-- Lagerbestand -->
                <DataGridTextColumn Header="Lagerbestand"
                                    Binding="{Binding Lagerbestand}"
                                    Width="*"/>

                <!-- Ablaufdatum -->
                <DataGridTextColumn Header="Ablaufdatum"
                                    Binding="{Binding AblaufDatum, StringFormat={}{0:dd.MM.yyyy}}"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IstAbgelaufen}" Value="True">
                                    <Setter Property="Foreground" Value="#FF5252"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding IstBaldAblaufend}" Value="True">
                                    <Setter Property="Foreground" Value="#FFC107"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- ErstelltAm -->
                <DataGridTextColumn Header="Erstellt am"
                                    Binding="{Binding ErstelltAm, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>