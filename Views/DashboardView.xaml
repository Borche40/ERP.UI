<UserControl x:Class="ERP.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:local="clr-namespace:ERP.UI.Views"
             xmlns:viewmodel="clr-namespace:ERP.UI.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:Dashboard}"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             >

    
    
        <!-- Puls-Animation за време на Laden -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Storyboard x:Key="Pulse">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.4" To="1.0"
                             Duration="0:0:0.8"
                             AutoReverse="True"
                             RepeatBehavior="Forever"/>
        </Storyboard>

        <Storyboard x:Key="BellBounceAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0"
                             To="-8"
                             Duration="0:0:0.12"
                             AutoReverse="True"
                             RepeatBehavior="2x"/>

            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0.7"
                             Duration="0:0:0.12"
                             AutoReverse="True"
                             RepeatBehavior="2x"/>
        </Storyboard>

        <Storyboard x:Key="BadgePulseAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0.4"
                             Duration="0:0:0.8"
                             AutoReverse="True"
                             RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="1.15"
                             Duration="0:0:0.8"
                             AutoReverse="True"
                             RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1"
                             To="1.15"
                             Duration="0:0:0.8"
                             AutoReverse="True"
                             RepeatBehavior="Forever"/>
        </Storyboard>

        <Storyboard x:Key="PopupOpenAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1" Duration="0:0:0.20"/>
            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                             From="-10"
                             To="0"
                             Duration="0:0:0.25"/>
        </Storyboard>
        <Storyboard x:Key="PopupCloseAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0"
                             To="10" Duration="0:0:0.15"/>
        </Storyboard>
    </UserControl.Resources>
    

    <!-- Dashboard -->
    <Grid Background="{DynamicResource Hintergrund}">

        
        <DockPanel Margin="16,0,0,0">
            <!-- 🔹 Logout копче горе-лево -->
            <Button Width="44" Height="44"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Margin="0,0,0,8"
        Command="{Binding BenutzerAbmelden}"
        ToolTip="Abmelden"
        Cursor="Hand"
        Background="#22FFFFFF"
        BorderBrush="#33FFFFFF"
        BorderThickness="1">
                <Button.Effect>
                    <DropShadowEffect Color="#00BFFF"
                          BlurRadius="12"
                          ShadowDepth="0"
                          Opacity="0.9"/>
                </Button.Effect>

                <TextBlock Text="&#xE7E8;"
               FontFamily="Segoe MDL2 Assets"
               Foreground="White"
               FontSize="15"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <!-- Hover ефект -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#55FFFFFF"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.15" ScaleY="1.15"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <!-- Top-Bar -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Top" >

                <TextBlock Text="Dashboard" FontSize="38"
                           FontWeight="SemiBold"
                           Margin="28,0,8,0"
                           Style="{StaticResource TietelText}"/>

                <!-- Статус-точка -->

                <Ellipse Width="18" Height="18" Margin="6,0,0,0" VerticalAlignment="Center"
         Fill="{Binding StatusBrush}" >
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IstPuls}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="pulseSb" Storyboard="{StaticResource Pulse}"/>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="pulseSb"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>





                <!-- Status Text -->
                <TextBlock Text="{Binding StatusText}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="Gray" Opacity="0.8"/>
            </StackPanel>

            <!-- Десно копче -->
            <!-- 🔔 Notifikationen + Aktualisieren -->
            <StackPanel Orientation="Horizontal"
            DockPanel.Dock="Top"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,20,0">

                <!-- 🔔 BEGIN: Warn-Bell -->
                <Grid x:Name="BellContainer"
          Margin="0,0,20,0"
          Cursor="Hand"
          ToolTip="Produkte laufen bald ab"
          MouseLeftButtonUp="BellContainer_MouseLeftButtonUp"
                      Width="40" Height="40">

                    <Grid.Resources>
                        <Storyboard x:Key="BadgePulseAnimation">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.4"
                                             To="1"
                                             Duration="0:0:0.8"
                                             AutoReverse="True"
                                             RepeatBehavior="Forever"/>
                        </Storyboard>
                    </Grid.Resources>
                    <Grid.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </Grid.RenderTransform>

                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HatWarnungen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource BadgePulseAnimation}"/>

                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    
                    
                    <!-- Bell Icon -->
                    <TextBlock Text="&#xEA8F;"
                   FontFamily="Segoe MDL2 Assets"
                   FontSize="26"
                   Foreground="White"
                   VerticalAlignment="Center"
                    HorizontalAlignment="Center"/>

                    <Border Background="#FFDC262C"
                            Width="20"
                            Height="20"
                            CornerRadius="10"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            
                            Visibility="{Binding HatWarnungen,Converter={StaticResource BooleanToVisibilityConverter}}">

                        <!-- 1,2.3.... Anzahl -->
                        <TextBlock Text="{Binding KritischeProduktAnzahl}"
                       Foreground="White"
                       FontSize="12"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       
                       Visibility="{Binding HatWarnungen,Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        
                        </Border>
                </Grid>


                <Popup x:Name="WarnungenPopup"
                       PlacementTarget="{Binding ElementName=BellContainer}"
                       Placement="Bottom"
                       StaysOpen="False"
                       IsOpen="{Binding IstWarnungsPanelSichtbar,Mode=TwoWay}" Closed="WarnungenPopup_Closed"
                       Opened="WarnungenPopup_Opened">
                    <Border Background="#FF1E1E2C"
                            BorderBrush="#FFDC262C"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,4,0,0">
                        <Border.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </Border.RenderTransform>

                        <StackPanel MinWidth="260">
                            <TextBlock Text="Produkte mit baldigem Ablaufdatum"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,4"/>
                            <Separator Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding KritischeProdukte}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="220"
                                    >
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <EventSetter Event="MouseDoubleClick"
                                         Handler="KritischeProdukteListBox_MouseDoubleClick"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                
                                
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#33111111"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,6,0,0">
                                            <StackPanel>
                                                <TextBlock Text="⚠ Produkte läuft bald ab "
                                                           FontWeight="Bold"
                                                           Foreground="#FFDC262C"/>
                                                <TextBlock Text="{Binding ProduktName}"
                                                           FontSize="14"
                                                           Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding AblaufDatum,StringFormat='Ablaufdatum:{0:dd.MM.yyyy}'}"
                                                           FontSize="12"
                                                           Foreground="LightGray"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <!--Optional kleiner Hinweis-->
                            <TextBlock Text="(Nur Produkte,die in den nächsten 3 Tagen ablaufen)"
                                       Foreground="Gray"
                                       FontSize="10"
                                       Margin="0,4,0,0"/>

                        </StackPanel>
                    </Border>
                </Popup>
                <!-- 🔔 END -->

                <!-- 🟦 Aktualisieren-Button -->
                <Button Content="Aktualisieren"
            Style="{StaticResource AkzentButton}"
            Command="{Binding AktualisierenCommand}"/>
            </StackPanel>


            <!-- Содржина -->
            <Grid Margin="0,40,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Картончиња -->
                <UniformGrid Rows="1" Columns="5" Grid.Row="0">
                    <Border Style="{StaticResource DashboardCardStyle}">
                        <Button Command="{Binding ÖffneKundenCommand}" Background="Transparent" BorderThickness="10" >
                            <StackPanel>
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                       Foreground="{StaticResource AkzentFarbe}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Kunden" Style="{StaticResource TietelText}"/>
                                <TextBlock Text="{Binding AnzahlKunden}" Style="{StaticResource Zahltext}"/>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>

                    <Border Style="{StaticResource DashboardCardStyle}">
                        <Button Command="{Binding ÖffneProdukteCommand}" Background="Transparent" BorderThickness="10">
                            <StackPanel>
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                       Foreground="{StaticResource AkzentFarbe}"/>
                                <TextBlock Text="Produkte" Style="{StaticResource TietelText}"/>
                                <TextBlock Text="{Binding AnzahlProdukte}" Style="{StaticResource Zahltext}"/>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button" >
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFE5F1FB"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                    </Style.Triggers>

                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>

                    <Border Style="{StaticResource DashboardCardStyle}">
                        <Button Command="{Binding AufgabenCommand}" Background="Transparent" BorderThickness="10">
                            <StackPanel>
                                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                       Foreground="{StaticResource AkzentFarbe}"/>
                                <TextBlock Text="Aufgaben" Style="{StaticResource TietelText}"/>
                                <TextBlock Text="{Binding AnzahlAufgabenOffen}" Style="{StaticResource Zahltext}"/>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFE5F1FB"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>

                    <Border Style="{StaticResource DashboardCardStyle}">
                        <Button Command="{Binding ÖffneBestellungenCommand}" Background="Transparent" BorderThickness="10">
                            <StackPanel>
                                <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                       Foreground="{StaticResource AkzentFarbe}"/>
                                <TextBlock Text="Bestellungen" Style="{StaticResource TietelText}"/>
                                <TextBlock Text="{Binding AnzahlBestellungenOffen}" Style="{StaticResource Zahltext}"/>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFE5F1FB"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>

                    <Border Style="{StaticResource KartenStyle}">


                        <StackPanel>
                            <TextBlock Text="&#xE7C8;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                       Foreground="{StaticResource AkzentFarbe}"/>
                            <TextBlock Text="Umsatz" Style="{StaticResource TietelText}"/>
                            <!--  Gesamtumsatz → UmsatzHeute -->
                            <TextBlock Text="{Binding UmsatzHeute, StringFormat=C}" Style="{StaticResource Zahltext}"/>
                        </StackPanel>

                    </Border>
                </UniformGrid>

               

                <!-- 🔸 Дијаграми долу -->
                <Grid Grid.Row="1" Margin="0,10,0,0" VerticalAlignment="Top">
                    <!--Drei gleichmäßig verteilte Spalten-->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        
                    </Grid.ColumnDefinitions>

                            <!-- 1 Kreisdiagramm Umsatz nach Monat-->
                    <Border Grid.Column="0" 
                            Style="{StaticResource DashboardCardStyle}"
                            Background="#FF1E1E2C"
                            CornerRadius="28"
                            Padding="16"
                            Margin="0,0,10,0"
                            MinHeight="320"
                            MinWidth="340">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                

                            </Grid.RowDefinitions>

                            <TextBlock Text="Umsatz nach Monaten :"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ERP_TextBrush}"
                                       Margin="0,0,0,10"/>
                            <oxy:PlotView Grid.Row="1" Model="{Binding UmsatzNachMonatenPlot}"
                                          Background="#1E1E2C"
                                          Padding="8"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          MinHeight="240"/>
                        </Grid>
                        
                    </Border>
                    
                    <!--2er Kreisdiagram Top 5 Produkte nach Umsatz  -->
                    <Border Grid.Column="1" Style="{StaticResource DashboardCardStyle}"
                            Background="#FF1E1E2C"
                            CornerRadius="28" 
                            Padding="16"
                            Height="330"
                            Width="370"
                            Margin="0,0,0,0"
                            MinHeight="320"
                            MaxWidth="340">


                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Top 5 Produkte nach Umsatz :"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ERP_TextBrush}"
                                       Margin="0,0,0,10"/>
                            <oxy:PlotView Grid.Row="1" Model="{Binding ProduktePlotModel}"
                                          Background="#1E1E2C"
                                          Padding="8"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          MinHeight="260"/>
                        </Grid>
                        
                    </Border>
                    
                    <!--3er Kreisdiagramm Bestellungen nach Status-->
                    <Border Grid.Column="2"
                            Style="{StaticResource DashboardCardStyle}"
                            Background="#FF1E1E2C"
                            CornerRadius="28"
                            Padding="16"
                            Margin="0,0,17,0"
                            MinHeight="320"
                            MinWidth="340">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!--Titel des Diagramms-->
                            <TextBlock Text="Bestellungen nach Status :"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ERP_TextBrush}"
                                       Margin="0,0,0,10"/>
                            <oxy:PlotView Grid.Row="1"
                                          Model="{Binding BestellungenNachStatusPlot}"
                                          Background="#1E1E2C"
                                          Padding="8"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          MinHeight="260"/>

                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
