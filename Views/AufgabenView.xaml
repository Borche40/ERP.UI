<UserControl x:Class="ERP.UI.Views.AufgabenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:ERP.UI.ViewModel;assembly=ERP.UI"
             mc:Ignorable="d"
             Background="#111318"
             d:DataContext="{d:DesignInstance Type=viewmodel:AufgabenViewModel}">

    <!-- ===================== Ressourcen ===================== -->
    <UserControl.Resources>
        <SolidColorBrush x:Key="A1.BgWindow" Color="#111318"/>
        <SolidColorBrush x:Key="A1.BgHeaderRow" Color="#181C26"/>
        <SolidColorBrush x:Key="A1.BgRow" Color="#151922"/>
        <SolidColorBrush x:Key="A1.BgRowHover" Color="#1B2330"/>
        <SolidColorBrush x:Key="A1.BgRowSelected" Color="#222D3C"/>
        <SolidColorBrush x:Key="A1.BorderSoft" Color="#262B3A"/>
        <SolidColorBrush x:Key="A1.TextMain" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="A1.TextSecondary" Color="#A0A3B0"/>

        <!-- Statusfarben -->
        <SolidColorBrush x:Key="Status.Offen" Color="#1976D2"/>
        <SolidColorBrush x:Key="Status.InBearbeitung" Color="#FF8F00"/>
        <SolidColorBrush x:Key="Status.Erledigt" Color="#2E7D32"/>
        <SolidColorBrush x:Key="Status.Überfällig" Color="#C62828"/>
        <SolidColorBrush x:Key="Status.Unbekannt" Color="#455A64"/>

        <!-- Prioritätfarben -->
        <SolidColorBrush x:Key="Prio.Niedrig" Color="#546E7A"/>
        <SolidColorBrush x:Key="Prio.Mittel" Color="#1976D2"/>
        <SolidColorBrush x:Key="Prio.Hoch" Color="#F9A825"/>
        <SolidColorBrush x:Key="Prio.Kritisch" Color="#D32F2F"/>
        <SolidColorBrush x:Key="Prio.Unbekannt" Color="#455A64"/>

        <!-- StatusBadgeTemplate -->
        <DataTemplate x:Key="StatusBadgeTemplate">
            <Border x:Name="Badge" Padding="14,4" CornerRadius="14" Background="#455A64">
                <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding StatusText}" Value="Offen">
                    <Setter TargetName="Badge" Property="Background" Value="{StaticResource Status.Offen}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="In Bearbeitung">
                    <Setter TargetName="Badge" Property="Background" Value="{StaticResource Status.InBearbeitung}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="Erledigt">
                    <Setter TargetName="Badge" Property="Background" Value="{StaticResource Status.Erledigt}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="Überfällig">
                    <Setter TargetName="Badge" Property="Background" Value="{StaticResource Status.Überfällig}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- PrioritätBadgeTemplate -->
        <DataTemplate x:Key="PrioritätBadgeTemplate">
            <Border x:Name="PrioBadge" Padding="12,4" CornerRadius="14" Background="#455A64">
                <TextBlock Text="{Binding PrioritätText}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding PrioritätText}" Value="Niedrig">
                    <Setter TargetName="PrioBadge" Property="Background" Value="{StaticResource Prio.Niedrig}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding PrioritätText}" Value="Mittel">
                    <Setter TargetName="PrioBadge" Property="Background" Value="{StaticResource Prio.Mittel}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding PrioritätText}" Value="Hoch">
                    <Setter TargetName="PrioBadge" Property="Background" Value="{StaticResource Prio.Hoch}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding PrioritätText}" Value="Kritisch">
                    <Setter TargetName="PrioBadge" Property="Background" Value="{StaticResource Prio.Kritisch}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Item Container Style -->
        <Style TargetType="ListViewItem" x:Key="TaskItemContainerStyle">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Resources>

    <!-- ===================== Layout ===================== -->
    <Grid Background="{StaticResource A1.BgWindow}" Margin="32,24,32,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Aufgabenliste -->
            
         
            <!-- Kommentarbereich -->
        </Grid.ColumnDefinitions>

        <!-- ================= Aufgabenliste ================= -->
        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <!-- ✅ NEU: Details-Panel -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Aufgabenübersicht" FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource A1.TextMain}" Margin="4,0,0,18"/>

            <!-- Toolbar -->
            <Grid Grid.Row="1" Background="#181A20" Height="52" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Margin="12,8" Padding="10,6"
                         Text="{Binding Suchtext, UpdateSourceTrigger=PropertyChanged}"
                         Background="#22242D" Foreground="White" BorderBrush="#2C2F36"
                         BorderThickness="1" FontSize="14" VerticalContentAlignment="Center" Height="36"/>

                <ComboBox Grid.Column="1" MinWidth="220" Margin="6,8,6,8" Height="36"
                          ItemsSource="{Binding StatusFilterOptionen}"
                          SelectedItem="{Binding AusgewählterStatusFilter}"
                          Background="#22242D" Foreground="Gray" BorderBrush="#2C2F36"
                          BorderThickness="1" Padding="10,2"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Content="Neue Aufgabe" Command="{Binding NeueAufgabeCommand}" Margin="6,0"
                            Padding="14,6" Background="#00C853" Foreground="White" FontWeight="SemiBold"/>
                    <Button Content="Bearbeiten" Command="{Binding BearbeitenCommand}" Margin="6,0"
                            Padding="14,6" Background="#1976D2" Foreground="White" FontWeight="SemiBold"/>
                    <Button Content="Als erledigt markieren" Command="{Binding MarkiereAlsErledigtCommand}"
                            Margin="6,0" Padding="14,6" Background="#03A9F4" Foreground="White" FontWeight="SemiBold"/>
                    <Button Content="Aktualisieren" Command="{Binding AktualisierenCommand}" Margin="6,0"
                            Padding="14,6" Background="#0091EA" Foreground="White" FontWeight="SemiBold"/>
                    <Button Content="Löschen" Command="{Binding LöschenCommand}" Margin="6,0"
                            Padding="14,6" Background="#E53935" Foreground="White" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>

            <!-- Header -->
            <Grid Grid.Row="2" Background="{StaticResource A1.BgHeaderRow}" Height="40" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="1.6*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Titel" Margin="18,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource A1.TextSecondary}" FontSize="13"/>
                <TextBlock Grid.Column="1" Text="Status" VerticalAlignment="Center"
                           Foreground="{StaticResource A1.TextSecondary}" FontSize="13"/>
                <TextBlock Grid.Column="2" Text="Zuständig" VerticalAlignment="Center"
                           Foreground="{StaticResource A1.TextSecondary}" FontSize="13"/>
                <TextBlock Grid.Column="3" Text="Fällig am" VerticalAlignment="Center"
                           Foreground="{StaticResource A1.TextSecondary}" FontSize="13"/>
                <TextBlock Grid.Column="4" Text="Priorität" VerticalAlignment="Center"
                           Foreground="{StaticResource A1.TextSecondary}" FontSize="13"/>
            </Grid>

            <!-- Aufgabenliste -->
            <ListView Grid.Row="3"
                      ItemsSource="{Binding AufgabenListe}"
                      SelectedItem="{Binding AusgewählteAufgabe, Mode=TwoWay}"
                      ItemContainerStyle="{StaticResource TaskItemContainerStyle}"
                      Background="Transparent" BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource A1.BgRow}" Margin="0,0,0,1" Padding="18,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="1.8*"/>
                                    <ColumnDefinition Width="1.6*"/>
                                    <ColumnDefinition Width="1.6*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Titel}" Foreground="{StaticResource A1.TextMain}"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <ContentControl Grid.Column="1" Content="{Binding}" ContentTemplate="{StaticResource StatusBadgeTemplate}"/>
                                <TextBlock Grid.Column="2" Text="{Binding BenutzerID}" Foreground="{StaticResource A1.TextSecondary}"
                                           FontSize="13"/>
                                <TextBlock Grid.Column="3" Text="{Binding FälligkeitsDatum, StringFormat={}{0:dd.MM.yyyy}}"
                                           Foreground="{StaticResource A1.TextMain}" FontSize="13"/>
                                <ContentControl Grid.Column="4" Content="{Binding}" ContentTemplate="{StaticResource PrioritätBadgeTemplate}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- ✅ NEU: Details Panel (Live-Preview der selektierten Aufgabe) -->
            <Border Grid.Row="4"
                    Margin="0,14,0,0"
                    Padding="14"
                    Background="#151922"
                    BorderBrush="{StaticResource A1.BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="10">

                <StackPanel>
                    <TextBlock Text="Ausgewählte Aufgabe – Details"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource A1.TextMain}"
                               Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            
                            <!--Fortschritt-->
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="TicketID:" Foreground="{StaticResource A1.TextSecondary}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AusgewählteAufgabe.TicketID,TargetNullValue='-' }"
                                   Foreground="{StaticResource A1.TextMain}"
                                   FontWeight="SemiBold" Margin="0,6,0,0"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Titel:" Foreground="{StaticResource A1.TextSecondary}" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding AusgewählteAufgabe.Titel, TargetNullValue='-'}"
                                   Foreground="{StaticResource A1.TextMain}"
                                   FontWeight="SemiBold" Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Beschreibung:" Foreground="{StaticResource A1.TextSecondary}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding AusgewählteAufgabe.Beschreibung, TargetNullValue='-'}"
                                   Foreground="{StaticResource A1.TextMain}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Status:" Foreground="{StaticResource A1.TextSecondary}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding AusgewählteAufgabe.StatusText, TargetNullValue='-'}"
                                   Foreground="{StaticResource A1.TextMain}"
                                   Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Zuständig:" Foreground="{StaticResource A1.TextSecondary}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="{Binding AusgewählteAufgabe.BenutzerID, TargetNullValue='-'}"
                                   Foreground="{StaticResource A1.TextMain}"
                                   Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Fällig am:" Foreground="{StaticResource A1.TextSecondary}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="1"
                                   Text="{Binding AusgewählteAufgabe.FälligkeitsDatum, StringFormat={}{0:dd.MM.yyyy}, TargetNullValue='-'}"
                                   Foreground="{StaticResource A1.TextMain}"
                                   Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Priorität:" Foreground="{StaticResource A1.TextSecondary}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="1"
                                   Text="{Binding AusgewählteAufgabe.PrioritätText, TargetNullValue='-'}"
                                   Foreground="{StaticResource A1.TextMain}"
                                   Margin="0,6,0,0"/>
                      
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Kommentarbereich  
        <Border Grid.Column="1" BorderBrush="#262B3A" BorderThickness="1,0,0,0"
                Background="#181C26" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Kommentare" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource A1.TextMain}" Margin="0,0,0,12"/>

                    <ListBox ItemsSource="{Binding Kommentare}" SelectedItem="{Binding AusgewählterKommentar}"
                             Background="#151922" Foreground="{StaticResource A1.TextMain}"
                             BorderBrush="#2C2F36" BorderThickness="1" Height="250"  Margin="0,0,0,12">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding KommentarText}"
                                               FontSize="14"
                                               Foreground="White"/>
                                    <TextBlock Text="{Binding ErstelltAm,StringFormat='{}{0:dd.MM.yyyyy HH:mm}'}"
                                               FontSize="11"
                                               Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBox Text="{Binding NeuerKommentarText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Background="#22242D" Foreground="{StaticResource A1.TextMain}"
                             BorderBrush="#2C2F36" BorderThickness="1" Height="90" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Senden" Command="{Binding KommentarHinzufügenCommand}"
                                Background="#00C853" Foreground="White" Margin="0,0,8,0"
                                Padding="14,6" FontWeight="SemiBold"/>
                        <Button Content="Löschen" Command="{Binding KommentarLöschenCommand}"
                                Background="#E53935" Foreground="White"
                                Padding="14,6" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <!- Ende Kommentarbereich -->
    </Grid>
</UserControl>
